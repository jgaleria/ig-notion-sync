# ─── Instagram Graph API ──────────────────────────────────────────────
# IG Business/Creator account ID (17-digit number from /me/accounts)
IG_USER_ID=

# Long-lived (60-day) access token, starts with EAA...
IG_ACCESS_TOKEN=

# Graph API version
IG_GRAPH_API_VERSION=v21.0

# App credentials (only needed to re-issue tokens before day 60)
META_APP_ID=
META_APP_SECRET=

# ─── Notion ───────────────────────────────────────────────────────────
# Internal integration secret, starts with ntn_ or secret_
NOTION_TOKEN=

# Data source ID for the Content database (UUID with dashes)
NOTION_DATA_SOURCE_ID=

# Notion-Version header
NOTION_VERSION=2025-09-03

# ─── Behavior ─────────────────────────────────────────────────────────
# If true, never write to Notion — only log what would be written
DRY_RUN=false

# Max posts to fetch from IG per run
MAX_POSTS=50
